# Copy to .env (or export) for the Node runtime — `npm run dev` / Docker / Railway / Render / DO / Fly.

# From the MailKite dashboard (https://app.mailkite.dev) — API keys page.
MAILKITE_API_KEY="mk_live_xxx"

# Webhook signing secret — dashboard → Webhooks. Used to verify x-mailkite-signature.
MAILKITE_WEBHOOK_SECRET="whsec_xxx"

# Optional.
PORT=3000
DATABASE_PATH=./data/inbox.db
