# Copy to .env (or export) for the Node runtime — `npm run dev` / Docker / Railway / Render / DO / Fly.

# There is NO API key: visitors sign into their own MailKite account with OAuth, and the app acts as
# them (reading only mail for domains they own). The OAuth client registers itself at runtime, so
# there's no client id/secret to set either.
#
# OPTIONAL account-wide fallback signing secret — dashboard → Webhooks. You usually don't need it:
# connecting a domain caches that route's own per-route secret, which /inbound verifies against.
# MAILKITE_WEBHOOK_SECRET="whsec_xxx"

# Optional.
PORT=3000
DATABASE_PATH=./data/inbox.db
# Override the OAuth issuer for local testing against a dev API. Defaults to https://mcp.mailkite.dev.
# MAILKITE_OAUTH_ISSUER=http://localhost:8787
