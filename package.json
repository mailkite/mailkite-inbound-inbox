{
  "name": "mailkite-inbound-inbox",
  "version": "0.1.0",
  "private": true,
  "description": "Your app's email inbox in one deploy — MailKite inbound webhook receiver + server-rendered inbox + reply, for Cloudflare Workers, Railway, Render, DigitalOcean, Fly, and Docker.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/node/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/node/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/app.test.ts",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^12.2.0",
    "hono": "^4.8.0",
    "mailkite": "^0.11.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.20.0"
  },
  "license": "MIT",
  "homepage": "https://mailkite.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mailkite/mailkite-inbound-inbox.git"
  }
}
